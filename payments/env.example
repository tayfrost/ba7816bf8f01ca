# ─────────────────────────────────────────────────────────────
# SentinelAI Payments Service — Environment Variables
# ─────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your values (do NOT commit .env to git)
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_NAME=SentinelAI Payments Service
APP_VERSION=1.0.0
DEBUG=False

# ── Database ─────────────────────────────────
# Must match the shared PostgreSQL instance used by the main backend
DATABASE_URL=postgresql+asyncpg://postgres:your_db_password_here@pgvector:5432/sentinelai

# ── Stripe ───────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — generated when you register the endpoint in Stripe Dashboard
# For local testing use Stripe CLI:  stripe listen --forward-to localhost:8001/api/v1/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ── URLs ─────────────────────────────────────
# URL of the frontend app (used for Stripe redirect after checkout)
FRONTEND_URL=http://localhost:3000

# URL of this payments service (used internally if needed)
PAYMENTS_SERVICE_URL=http://localhost:8001
