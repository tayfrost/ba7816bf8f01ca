GRPC_SECRET=sentinel-grpc-internal
HF_TOKEN=your-hf-token
HF_USERNAME=your-hf-username
HF_MODEL=OguzhanKOG/sentinelai-bert-filter
MODEL_NAME=bert-base-uncased

max_token_length=128
overlap=32
threshold=0.5

# Escalation thresholds
# Escalate to AI if predicted neutral/humor_sarcasm but confidence is below this
SOFT_CONF_THRESHOLD=0.8
# Escalate to AI if a risk category scores at or above this (even if not "winner")
RISK_ESCALATION_FLOOR=0.2
