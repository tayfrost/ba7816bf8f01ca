FROM python:3.11-slim

WORKDIR /app

# ── System dependencies ───────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# ── Python dependencies ───────────────────────────────────────────
COPY webhooks/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# ── Generate filter proto stubs ───────────────────────────────────
COPY protos/filter ./protos/filter
RUN python -m grpc_tools.protoc \
    -I./protos \
    --python_out=. \
    --grpc_python_out=. \
    ./protos/filter/v1/filter.proto && \
    touch filter/__init__.py && \
    touch filter/v1/__init__.py

# ── Application source ────────────────────────────────────────────
COPY webhooks/ .
ENV PYTHONPATH=/app

# ── Stub out the backend DB package ──────────────────────────────
RUN mkdir -p backend/New_database && \
    touch backend/__init__.py && \
    touch backend/New_database/__init__.py && \
    printf 'class Session:\n    def __init__(self): pass\n    def execute(self, *a, **kw): return self\n    def scalar_one_or_none(self): return None\n    def close(self): pass\ndef create_user(*a, **kw): pass\ndef get_user_by_id(*a, **kw): pass\ndef list_companies(*a, **kw): return []\n' \
        > backend/New_database/new_crud.py && \
    printf 'def create_google_mailbox(*a, **kw): pass\ndef get_google_mailbox_by_email(*a, **kw): pass\ndef update_google_mailbox_token(*a, **kw): pass\ndef set_google_mailbox_history_id(*a, **kw): pass\ndef update_google_mailbox_watch_expiration(*a, **kw): pass\ndef list_google_mailboxes_for_company(*a, **kw): return []\ndef create_workspace(*a, **kw): pass\ndef get_workspace_by_team_id(*a, **kw): pass\ndef update_workspace_token(*a, **kw): pass\ndef create_slack_account(*a, **kw): pass\ndef get_slack_account(*a, **kw): pass\ndef update_slack_account_email(*a, **kw): pass\ndef create_message_incident(*a, **kw): pass\ndef create_incident_scores(*a, **kw): pass\n' \
        > backend/New_database/new_crud_second_half.py && \
    printf 'class Company: pass\nclass User: pass\nclass GoogleMailbox: pass\nclass SlackWorkspace: pass\nclass SlackAccount: pass\nclass MessageIncident: pass\nclass IncidentScores: pass\n' \
        > backend/New_database/new_oop.py

# ── Entry point ───────────────────────────────────────────────────
CMD ["pytest", "app/tests/", "-v", "--tb=short", \
     "--ignore=app/tests/test_filter_integration.py"]